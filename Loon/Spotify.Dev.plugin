#!name=Spotify去广告
#!desc=无需脚本即可移除播放广告，恢复歌手列表的正常展示\n首次使用或修改参数需重新登录以生效
#!openUrl=https://apps.apple.com/app/id324684580
#!author=app2smile[https://github.com/app2smile], 001ProMax[https://github.com/001ProMax]
#!tag=去广告
#!system=
#!system_version=
#!loon_version=3.2.4(787)
#!homepage=https://github.com/luestr/ProxyResource/blob/main/README.md
#!icon=https://raw.githubusercontent.com/luestr/IconResource/main/App_icon/120px/Spotify.png
#!date=2025-06-11 00:00:00

[Rewrite]
^https:\/\/(?:\w+-spclient|spclient\.wg)\.spotify\.com\/pendragon\/ reject-dict
^https:\/\/(?:\w+-spclient|spclient\.wg)\.spotify\.com\/artistview\/v1\/artist\/(.*)&platform=iphone header https://spclient.wg.spotify.com/artistview/v1/artist/$2&platform=ipad
^https:\/\/(?:\w+-spclient|spclient\.wg)\.spotify\.com\/(bootstrap\/v1\/bootstrap|user-customization-service\/v1\/customize) https://surge.trigram-masques-8r.workers.dev/$1 header

[MitM]
hostname = *-spclient.spotify.com, spclient.wg.spotify.com
