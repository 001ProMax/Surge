#!name=Spotify
#!desc=AD
#!category=App
#!arguments=Mock:"https://mock.trigram-masques-8r.workers.dev/music"

[URL Rewrite]
# 移除追踪
^https:\/\/(?:spclient\.wg|[a-z0-9]+-spclient)\.spotify\.com(?::443)?\/(?:ad-|gabo|pendragon|social) - reject
# 移除广告
^https:\/\/(?:spclient\.wg|[a-z0-9]+-spclient)\.spotify\.com(?::443)?\/(user-customization-service|bootstrap) {{{Mock}}}/$1

[MITM]
hostname = %INSERT% spclient.wg.spotify.com, g*-spclient.spotify.com
